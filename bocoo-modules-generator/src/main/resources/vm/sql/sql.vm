insert into sys_role_menu (role_id, menu_id, tenant_id)
select 1, menu_id, 1
from sys_menu
where tenant_id = 1
  and menu_id in (${table.menuIds[0]}, ${table.menuIds[1]}, ${table.menuIds[2]}, ${table.menuIds[3]}, ${table.menuIds[4]}, ${table.menuIds[5]})
on conflict do nothing;

