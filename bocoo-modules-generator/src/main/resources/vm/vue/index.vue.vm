<style scoped>
.${businessName}-drawer-footer {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
}
</style>

<script setup name="${BusinessName}">
  import { list${BusinessName}, get${BusinessName}, del${BusinessName}, add${BusinessName}, update${BusinessName} } from "@/api/${moduleName}/${businessName}";
  import { formatUtc, withUtcDateRangeParams } from "@/utils/datetime";
  import { formatInch } from "@/utils/businessNumber";
  import { getMessage } from "@/locales";
  import { useLocaleStore } from "@/stores/locale";

const { proxy } = getCurrentInstance();
const localeStore = useLocaleStore();
const t = (key, params) => {
  const message = getMessage(key, localeStore.language);
  if (!params) return message;
  return Object.entries(params).reduce((text, [name, value]) => text.replaceAll(`{${name}}`, String(value)), message);
};
const fieldLabel = (field) => t('${moduleName}.${businessName}.field.' + field);
  #if(${dicts} != '')
#set($dictsNoSymbol=$dicts.replace("'", ""))
    const { ${dictsNoSymbol} } = proxy.useDict(${dicts});
  #end

  const ${businessName}List = ref([]);
  #if($table.sub)
    const ${subclassName}List = ref([]);
  #end
  const open = ref(false);
  const buttonLoading = ref(false);
  const loading = ref(true);
  const ids = ref([]);
  const showSearch = ref(true);
  #if($table.sub)
    const checked${subClassName} = ref([]);
  #end
  const total = ref(0);
  const title = ref("");
  const single = computed(() => ids.value.length !== 1);
  const multiple = computed(() => ids.value.length === 0);
  #foreach ($column in $columns)
#if($column.htmlType == "datetime" && $column.queryType == "BETWEEN")
#set($AttrName=$column.javaField.substring(0,1).toUpperCase() + ${column.javaField.substring(1)})
    const daterange${AttrName} = ref([]);
  #end
#end

  const data = reactive({
    form: {},
    queryParams: {
      pageNum: 1,
      pageSize: 10,
  #foreach ($column in $columns)
#if($column.query)
    $column.javaField: undefined#if($foreach.count != $columns.size()),#end
#end
#end
  },
  rules: {
  #foreach ($column in $columns)
#if($column.required)
#set($parentheseIndex=$column.columnComment.indexOf("’╝ł"))
#if($parentheseIndex != -1)
#set($comment=$column.columnComment.substring(0, $parentheseIndex))
#else
#set($comment=$column.columnComment)
#end
    $column.javaField: [
      { required: true, message: t('common.required'), trigger: #if($column.htmlType == "select" || $column.htmlType == "radio")"change"#else"blur"#end }
    ]#if($foreach.count != $columns.size()),#end
#end
#end
  }
});

const { queryParams, form, rules } = toRefs(data);

/** Query ${functionName} list */
function getList() {
  loading.value = true;
  let params = { ...queryParams.value };
#foreach ($column in $columns)
#if($column.htmlType == "datetime" && $column.queryType == "BETWEEN")
#set($AttrName=$column.javaField.substring(0,1).toUpperCase() + ${column.javaField.substring(1)})
  params = withUtcDateRangeParams(params, daterange${AttrName}.value, 'begin${AttrName}', 'end${AttrName}');
#end
#end
  list${BusinessName}(params).then(response => {
  ${businessName}List.value = response.rows;
    total.value = response.total;
    loading.value = false;
  });
}

// Cancel
function cancel() {
  open.value = false;
  reset();
}

// Reset form
function reset() {
  form.value = {
  #foreach ($column in $columns)
#if($column.htmlType == "checkbox")
    $column.javaField: []#if($foreach.count != $columns.size()),#end
#else
    $column.javaField: null#if($foreach.count != $columns.size()),#end
#end
#end
  };
  #if($table.sub)
  ${subclassName}List.value = [];
  #end
  proxy.resetForm("${businessName}Ref");
}

/** Search */
function handleQuery() {
  queryParams.value.pageNum = 1;
  getList();
}

  #if($columns.size()>2)
    /** Reset search */
    function resetQuery() {
    #foreach ($column in $columns)
    #if($column.htmlType == "datetime" && $column.queryType == "BETWEEN")
      #set($AttrName=$column.javaField.substring(0,1).toUpperCase() + ${column.javaField.substring(1)})
      daterange${AttrName}.value = [];
    #end
  #end
    proxy.resetForm("queryRef");
    handleQuery();
  }
  #end

/** Selection change */
function handleSelectionChange(selection) {
  ids.value = selection.map(item => item.${pkColumn.javaField});
}

  /** Add */
  function handleAdd() {
    reset();
    open.value = true;
    title.value = t('${moduleName}.${businessName}.addTitle');
}

/** Update */
function handleUpdate(row) {
  reset();
  const _${pkColumn.javaField} = row?.${pkColumn.javaField} || ids.value[0]
  get${BusinessName}(_${pkColumn.javaField}).then(response => {
    form.value = response.data;
  #foreach ($column in $columns)
#if($column.htmlType == "checkbox")
    form.value.$column.javaField = form.value.${column.javaField}.split(",");
  #end
#end
#if($table.sub)
    ${subclassName}List.value = response.data.${subclassName}List;
#end
  open.value = true;
  title.value = t('${moduleName}.${businessName}.editTitle');
  });
}

/** Submit */
function submitForm() {
  proxy.#[[$]]#refs["${businessName}Ref"].validate(valid => {
    if (valid) {
      buttonLoading.value = true;
#foreach ($column in $columns)
#if($column.htmlType == "checkbox")
      form.value.$column.javaField = form.value.${column.javaField}.join(",");
#end
#end
#if($table.sub)
      form.value.${subclassName}List = ${subclassName}List.value;
#end
      if (form.value.${pkColumn.javaField} != null) {
        update${BusinessName}(form.value).then(response => {
          proxy.#[[$modal]]#.msgSuccess(t('common.editSuccess'));
          open.value = false;
          getList();
        }).finally(() => {
          buttonLoading.value = false;
        });
      } else {
        add${BusinessName}(form.value).then(response => {
          proxy.#[[$modal]]#.msgSuccess(t('common.addSuccess'));
          open.value = false;
          getList();
        }).finally(() => {
          buttonLoading.value = false;
        });
      }
    }
  });
}

/** Delete */
function handleDelete(row) {
  const _${pkColumn.javaField}s = row?.${pkColumn.javaField} || ids.value;
  proxy.#[[$modal]]#.confirm(t('${moduleName}.${businessName}.deleteConfirm', { ids: _${pkColumn.javaField}s })).then(function() {
    loading.value = true;
    return del${BusinessName}(_${pkColumn.javaField}s);
  }).then(() => {
    loading.value = true;
    getList();
    proxy.#[[$modal]]#.msgSuccess(t('common.deleteSuccess'));
  }).catch(() => {
  }).finally(() => {
    loading.value = false;
  });
}

#if($table.sub)
/** ${subTable.functionName} row index */
function row${subClassName}Index({ row, rowIndex }) {
  row.index = rowIndex + 1;
}

/** Add ${subTable.functionName} row */
function handleAdd${subClassName}() {
  let obj = {};
#foreach($column in $subTable.columns)
#if($column.pk || $column.javaField == ${subTableFkclassName})
#elseif($column.list && "" != $javaField)
  obj.$column.javaField = "";
#end
#end
  ${subclassName}List.value.push(obj);
}

/** Delete ${subTable.functionName} row */
function handleDelete${subClassName}() {
  if (checked${subClassName}.value.length == 0) {
    proxy.#[[$modal]]#.msgError(t('${moduleName}.${businessName}.selectSubToDelete'));
  } else {
    const ${subclassName}s = ${subclassName}List.value;
    const checked${subClassName}s = checked${subClassName}.value;
    ${subclassName}List.value = ${subclassName}s.filter(function(item) {
      return checked${subClassName}s.indexOf(item.index) == -1
    });
  }
}

#end
/** Export */
function handleExport() {
  proxy.download('${moduleName}/${businessName}/export', {
    ...queryParams.value
  }, `${businessName}_#[[${Date.now()}]]#.xlsx`)
}

getList();
</script>
