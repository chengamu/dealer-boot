<template>
  <div class="app-container">
    <el-form v-show="showSearch" ref="queryRef" :model="queryParams" :inline="true" label-width="80px">
      #foreach($column in $columns)
        #if($column.query)
          #set($dictType=$column.dictType)
          #set($AttrName=$column.javaField.substring(0,1).toUpperCase() + ${column.javaField.substring(1)})
          #set($parentheseIndex=$column.columnComment.indexOf("（"))
          #if($parentheseIndex != -1)
            #set($comment=$column.columnComment.substring(0, $parentheseIndex))
          #else
            #set($comment=$column.columnComment)
          #end
          #set($numberMode="")
          #if($column.htmlType == "number-count")#set($numberMode="COUNT")#end
          #if($column.htmlType == "number-quantity")#set($numberMode="QUANTITY")#end
          #if($column.htmlType == "number-unit-price")#set($numberMode="UNIT_PRICE")#end
          #if($column.htmlType == "number-money")#set($numberMode="MONEY")#end
          #if($column.htmlType == "number-rate")#set($numberMode="RATE")#end
          #if($column.htmlType == "inch")
            <el-form-item :label="fieldLabel('${column.javaField}')" prop="${column.javaField}">
              <BusinessInchInput v-model="queryParams.${column.javaField}" />
            </el-form-item>
          #elseif($numberMode != "")
            <el-form-item :label="fieldLabel('${column.javaField}')" prop="${column.javaField}">
              <BusinessNumberInput v-model="queryParams.${column.javaField}" mode="$numberMode" />
            </el-form-item>
          #elseif($column.htmlType == "input" || $column.htmlType == "textarea")
            <el-form-item :label="fieldLabel('${column.javaField}')" prop="${column.javaField}">
              <el-input
                v-model="queryParams.${column.javaField}"
                :placeholder="fieldLabel('${column.javaField}')"
                clearable
                style="width: 240px"
                @keyup.enter="handleQuery"
              />
            </el-form-item>
          #elseif(($column.htmlType == "select" || $column.htmlType == "radio") && "" != $dictType)
            <el-form-item :label="fieldLabel('${column.javaField}')" prop="${column.javaField}">
              <el-select v-model="queryParams.${column.javaField}" :placeholder="t('common.selectPlaceholder')" clearable filterable style="width: 200px">
                <el-option
                  v-for="dict in ${dictType}"
                  :key="dict.value"
                  :label="dict.label"
                  :value="dict.value"
                />
              </el-select>
            </el-form-item>
          #elseif(($column.htmlType == "select" || $column.htmlType == "radio") && $dictType)
            <el-form-item :label="fieldLabel('${column.javaField}')" prop="${column.javaField}">
              <el-select v-model="queryParams.${column.javaField}" :placeholder="t('common.selectPlaceholder')" clearable filterable style="width: 200px">
                <el-option :label="t('common.selectPlaceholder')" value="" />
              </el-select>
            </el-form-item>
          #elseif($column.htmlType == "datetime" && $column.queryType != "BETWEEN")
            <el-form-item :label="fieldLabel('${column.javaField}')" prop="${column.javaField}">
              <el-date-picker clearable
                              v-model="queryParams.${column.javaField}"
                              type="date"
                              value-format="YYYY-MM-DD"
                              :placeholder="t('common.selectPlaceholder')">
              </el-date-picker>
            </el-form-item>
          #elseif($column.htmlType == "datetime" && $column.queryType == "BETWEEN")
            <el-form-item :label="fieldLabel('${column.javaField}')" style="width: 330px">
              <el-date-picker
                v-model="daterange${AttrName}"
                type="daterange"
                range-separator="-"
                  :start-placeholder="t('common.startDate')"
                  :end-placeholder="t('common.endDate')"
                :default-time="[new Date(2000, 1, 1, 0, 0, 0), new Date(2000, 1, 1, 23, 59, 59)]"
              ></el-date-picker>
            </el-form-item>
          #end
        #end
      #end
      <el-form-item>
        <el-button type="primary" icon="Search" @click="handleQuery">{{ t('common.search') }}</el-button>
        #if($columns.size()>2)
          <el-button icon="Refresh" @click="resetQuery">{{ t('common.reset') }}</el-button>
        #end
      </el-form-item>
    </el-form>

    <el-row :gutter="10" class="mb8">
      <el-col :span="1.5">
        <el-button
          type="primary"
          plain
          icon="Plus"
          @click="handleAdd"
          v-hasPermi="['${moduleName}:${businessName}:add']"
        >{{ t('common.add') }}</el-button>
      </el-col>
      <el-col :span="1.5">
        <el-button
          type="info"
          plain
          icon="Sort"
          @click="toggleExpandAll"
        >{{ t('common.expandCollapse') }}</el-button>
      </el-col>
      <right-toolbar v-model:showSearch="showSearch" @queryTable="getList" />
    </el-row>

    <el-table
      v-if="refreshTable"
      v-loading="loading"
      :data="${businessName}List"
      row-key="${treeCode}"
      :default-expand-all="isExpandAll"
      :tree-props="{children: 'children', hasChildren: 'hasChildren'}"
    >
      #foreach($column in $columns)
        #set($javaField=$column.javaField)
        #set($parentheseIndex=$column.columnComment.indexOf("（"))
        #if($parentheseIndex != -1)
          #set($comment=$column.columnComment.substring(0, $parentheseIndex))
        #else
          #set($comment=$column.columnComment)
        #end
        #set($numberMode="")
        #if($column.htmlType == "number-count")#set($numberMode="COUNT")#end
        #if($column.htmlType == "number-quantity")#set($numberMode="QUANTITY")#end
        #if($column.htmlType == "number-unit-price")#set($numberMode="UNIT_PRICE")#end
        #if($column.htmlType == "number-money")#set($numberMode="MONEY")#end
        #if($column.htmlType == "number-rate")#set($numberMode="RATE")#end
        #if($column.pk)
        #elseif($column.list && $column.htmlType == "inch")
          <el-table-column :label="fieldLabel('${column.javaField}')" align="right" prop="${javaField}">
            <template #default="scope">{{ formatInch(scope.row.${javaField}) }}</template>
          </el-table-column>
        #elseif($column.list && $numberMode != "")
          <el-table-column :label="fieldLabel('${column.javaField}')" align="right" prop="${javaField}">
            <template #default="scope"><BusinessNumberText :value="scope.row.${javaField}" mode="$numberMode" /></template>
          </el-table-column>
        #elseif($column.list && $column.htmlType == "datetime")
          <el-table-column :label="fieldLabel('${column.javaField}')" align="center" prop="${javaField}" width="180">
            <template #default="scope">
              <span>{{ formatUtc(scope.row.${javaField}) }}</span>
            </template>
          </el-table-column>
        #elseif($column.list && $column.htmlType == "imageUpload")
          <el-table-column :label="fieldLabel('${column.javaField}')" align="center" prop="${javaField}" width="100">
            <template #default="scope">
              <image-preview :src="scope.row.${javaField}" :width="50" :height="50"/>
            </template>
          </el-table-column>
        #elseif($column.list && $column.dictType && "" != $column.dictType)
          <el-table-column :label="fieldLabel('${column.javaField}')" align="center" prop="${javaField}">
            <template #default="scope">
              #if($column.htmlType == "checkbox")
                <dict-tag :options="${column.dictType}" :value="scope.row.${javaField} ? scope.row.${javaField}.split(',') : []"/>
              #else
                <dict-tag :options="${column.dictType}" :value="scope.row.${javaField}"/>
              #end
            </template>
          </el-table-column>
        #elseif($column.list && "" != $javaField)
          #if(${foreach.index} == 1)
            <el-table-column :label="fieldLabel('${column.javaField}')" prop="${javaField}" />
          #else
            <el-table-column :label="fieldLabel('${column.javaField}')" align="center" prop="${javaField}" />
          #end
        #end
      #end
      <el-table-column :label="t('common.operate')" align="center" class-name="small-padding fixed-width">
        <template #default="scope">
          <el-button link type="primary" icon="Edit" @click="handleUpdate(scope.row)" v-hasPermi="['${moduleName}:${businessName}:edit']">{{ t('common.edit') }}</el-button>
          <el-button link type="primary" icon="Plus" @click="handleAdd(scope.row)" v-hasPermi="['${moduleName}:${businessName}:add']">{{ t('common.add') }}</el-button>
          <el-button link type="primary" icon="Delete" @click="handleDelete(scope.row)" v-hasPermi="['${moduleName}:${businessName}:remove']">{{ t('common.delete') }}</el-button>
        </template>
      </el-table-column>
    </el-table>

    <!-- Add or update ${functionName} drawer -->
    <el-drawer :title="title" v-model="open" size="520px" append-to-body destroy-on-close @closed="reset">
      <el-form ref="${businessName}Ref" :model="form" :rules="rules" label-width="80px">
        #foreach($column in $columns)
          #set($field=$column.javaField)
          #if($column.insert && !$column.pk)
            #set($parentheseIndex=$column.columnComment.indexOf("（"))
            #if($parentheseIndex != -1)
              #set($comment=$column.columnComment.substring(0, $parentheseIndex))
            #else
              #set($comment=$column.columnComment)
            #end
            #set($dictType=$column.dictType)
            #if("" != $treeParentCode && $column.javaField == $treeParentCode)
              <el-form-item :label="fieldLabel('${column.javaField}')" prop="${treeParentCode}">
                <el-tree-select
                  v-model="form.${treeParentCode}"
                  :data="${businessName}Options"
                  :props="{ value: '${treeCode}', label: '${treeName}', children: 'children' }"
                  value-key="${treeCode}"
                  :placeholder="t('common.selectPlaceholder')"
                  check-strictly
                />
              </el-form-item>
            #else
            #set($numberMode="")
            #if($column.htmlType == "number-count")#set($numberMode="COUNT")#end
            #if($column.htmlType == "number-quantity")#set($numberMode="QUANTITY")#end
            #if($column.htmlType == "number-unit-price")#set($numberMode="UNIT_PRICE")#end
            #if($column.htmlType == "number-money")#set($numberMode="MONEY")#end
            #if($column.htmlType == "number-rate")#set($numberMode="RATE")#end
            #if($column.htmlType == "inch")
              <el-form-item :label="fieldLabel('${column.javaField}')" prop="${field}">
                <BusinessInchInput v-model="form.${field}" />
              </el-form-item>
            #elseif($numberMode != "")
              <el-form-item :label="fieldLabel('${column.javaField}')" prop="${field}">
                <BusinessNumberInput v-model="form.${field}" mode="$numberMode" />
              </el-form-item>
            #elseif($column.htmlType == "input")
              <el-form-item :label="fieldLabel('${column.javaField}')" prop="${field}">
                <el-input v-model="form.${field}" :placeholder="fieldLabel('${column.javaField}')" />
              </el-form-item>
            #elseif($column.htmlType == "imageUpload")
              <el-form-item :label="fieldLabel('${column.javaField}')" prop="${field}">
                <image-upload v-model="form.${field}"/>
              </el-form-item>
            #elseif($column.htmlType == "fileUpload")
              <el-form-item :label="fieldLabel('${column.javaField}')" prop="${field}">
                <file-upload v-model="form.${field}"/>
              </el-form-item>
            #elseif($column.htmlType == "editor")
              <el-form-item :label="fieldLabel('${column.javaField}')">
                <editor v-model="form.${field}" :min-height="192"/>
              </el-form-item>
            #elseif($column.htmlType == "select" && "" != $dictType)
              <el-form-item :label="fieldLabel('${column.javaField}')" prop="${field}">
                <el-select v-model="form.${field}" :placeholder="t('common.selectPlaceholder')" clearable filterable style="width: 100%">
                  <el-option
                    v-for="dict in ${dictType}"
                    :key="dict.value"
                    :label="dict.label"
                    #if($column.javaType == "Integer" || $column.javaType == "Long")
                    :value="parseInt(dict.value)"
                    #else
                    :value="dict.value"
                    #end
                  ></el-option>
                </el-select>
              </el-form-item>
            #elseif($column.htmlType == "select" && $dictType)
              <el-form-item :label="fieldLabel('${column.javaField}')" prop="${field}">
                <el-select v-model="form.${field}" :placeholder="t('common.selectPlaceholder')" clearable filterable style="width: 100%">
                  <el-option :label="t('common.selectPlaceholder')" value="" />
                </el-select>
              </el-form-item>
            #elseif($column.htmlType == "checkbox" && "" != $dictType)
              <el-form-item :label="fieldLabel('${column.javaField}')" prop="${field}">
                <el-checkbox-group v-model="form.${field}">
                  <el-checkbox
                    v-for="dict in ${dictType}"
                    :key="dict.value"
                    :label="dict.value">
                    {{dict.label}}
                  </el-checkbox>
                </el-checkbox-group>
              </el-form-item>
            #elseif($column.htmlType == "checkbox" && $dictType)
              <el-form-item :label="fieldLabel('${column.javaField}')" prop="${field}">
                <el-checkbox-group v-model="form.${field}">
                  <el-checkbox>{{ t('common.selectPlaceholder') }}</el-checkbox>
                </el-checkbox-group>
              </el-form-item>
            #elseif($column.htmlType == "radio" && "" != $dictType)
              <el-form-item :label="fieldLabel('${column.javaField}')" prop="${field}">
                <el-radio-group v-model="form.${field}">
                  <el-radio
                    v-for="dict in ${dictType}"
                    :key="dict.value"
                    #if($column.javaType == "Integer" || $column.javaType == "Long")
                    :label="parseInt(dict.value)"
                    #else
                    :label="dict.value"
                    #end
                  >{{dict.label}}</el-radio>
                </el-radio-group>
              </el-form-item>
            #elseif($column.htmlType == "radio" && $dictType)
              <el-form-item :label="fieldLabel('${column.javaField}')" prop="${field}">
                <el-radio-group v-model="form.${field}">
                  <el-radio label="1">{{ t('common.selectPlaceholder') }}</el-radio>
                </el-radio-group>
              </el-form-item>
            #elseif($column.htmlType == "datetime")
              <el-form-item :label="fieldLabel('${column.javaField}')" prop="${field}">
                <el-date-picker clearable
                                v-model="form.${field}"
                                type="datetime"
                                :placeholder="t('common.selectPlaceholder')">
                </el-date-picker>
              </el-form-item>
            #elseif($column.htmlType == "textarea")
              <el-form-item :label="fieldLabel('${column.javaField}')" prop="${field}">
                <el-input v-model="form.${field}" type="textarea" :placeholder="t('common.required')" />
              </el-form-item>
            #end
            #end
          #end
        #end
      </el-form>
      <template #footer>
        <div class="${businessName}-drawer-footer">
          <el-button type="primary" @click="submitForm">{{ t('common.confirm') }}</el-button>
          <el-button @click="cancel">{{ t('common.cancel') }}</el-button>
        </div>
      </template>
    </el-drawer>
  </div>
</template>

<style scoped>
.${businessName}-drawer-footer {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
}
</style>

<script setup name="${BusinessName}">
  import { list${BusinessName}, get${BusinessName}, del${BusinessName}, add${BusinessName}, update${BusinessName} } from "@/api/${moduleName}/${businessName}";
  import { formatUtc, withUtcDateRangeParams } from "@/utils/datetime";
  import { formatInch } from "@/utils/businessNumber";
  import { getMessage } from "@/locales";
  import { useLocaleStore } from "@/stores/locale";

const { proxy } = getCurrentInstance();
const localeStore = useLocaleStore();
const t = (key, params) => {
  const message = getMessage(key, localeStore.language);
  if (!params) return message;
  return Object.entries(params).reduce((text, [name, value]) => text.replaceAll(`{${name}}`, String(value)), message);
};
const fieldLabel = (field) => t('${moduleName}.${businessName}.field.' + field);
  #if(${dicts} != '')
#set($dictsNoSymbol=$dicts.replace("'", ""))
    const { ${dictsNoSymbol} } = proxy.useDict(${dicts});
  #end

  const ${businessName}List = ref([]);
const ${businessName}Options = ref([]);
const open = ref(false);
const buttonLoading = ref(false);
const loading = ref(true);
const showSearch = ref(true);
const title = ref("");
const isExpandAll = ref(true);
const refreshTable = ref(true);
  #foreach ($column in $columns)
#if($column.htmlType == "datetime" && $column.queryType == "BETWEEN")
#set($AttrName=$column.javaField.substring(0,1).toUpperCase() + ${column.javaField.substring(1)})
    const daterange${AttrName} = ref([]);
  #end
#end

  const data = reactive({
    form: {},
    queryParams: {
  #foreach ($column in $columns)
#if($column.query)
    $column.javaField: undefined#if($foreach.count != $columns.size()),#end
#end
#end
  },
  rules: {
  #foreach ($column in $columns)
#if($column.required)
#set($parentheseIndex=$column.columnComment.indexOf("（"))
#if($parentheseIndex != -1)
#set($comment=$column.columnComment.substring(0, $parentheseIndex))
#else
#set($comment=$column.columnComment)
#end
    $column.javaField: [
      { required: true, message: t('common.required'), trigger: #if($column.htmlType == "select" || $column.htmlType == "radio")"change"#else"blur"#end }
    ]#if($foreach.count != $columns.size()),#end
#end
#end
  }
});

const { queryParams, form, rules } = toRefs(data);

/** Query ${functionName} list */
function getList() {
  loading.value = true;
  let params = { ...queryParams.value };
#foreach ($column in $columns)
#if($column.htmlType == "datetime" && $column.queryType == "BETWEEN")
#set($AttrName=$column.javaField.substring(0,1).toUpperCase() + ${column.javaField.substring(1)})
  params = withUtcDateRangeParams(params, daterange${AttrName}.value, 'begin${AttrName}', 'end${AttrName}');
#end
#end
  list${BusinessName}(params).then(response => {
  ${businessName}List.value = proxy.handleTree(response.data, "${treeCode}", "${treeParentCode}");
    loading.value = false;
  });
}

/** Query ${functionName} tree select data */
function getTreeselect() {
  list${BusinessName}().then(response => {
  ${businessName}Options.value = [];
    const data = { ${treeCode}: 0, ${treeName}: t('${moduleName}.${businessName}.topNode'), children: [] };
    data.children = proxy.handleTree(response.data, "${treeCode}", "${treeParentCode}");
  ${businessName}Options.value.push(data);
  });
}

// Cancel
function cancel() {
  open.value = false;
  reset();
}

// Reset form
function reset() {
  form.value = {
  #foreach ($column in $columns)
#if($column.htmlType == "checkbox")
    $column.javaField: []#if($foreach.count != $columns.size()),#end
#else
    $column.javaField: null#if($foreach.count != $columns.size()),#end
#end
#end
  };
  proxy.resetForm("${businessName}Ref");
}

/** Search */
function handleQuery() {
  getList();
}

  #if($columns.size()>2)
    /** Reset search */
    function resetQuery() {
    #foreach ($column in $columns)
#if($column.htmlType == "datetime" && $column.queryType == "BETWEEN")
#set($AttrName=$column.javaField.substring(0,1).toUpperCase() + ${column.javaField.substring(1)})
      daterange${AttrName}.value = [];
    #end
#end
    proxy.resetForm("queryRef");
    handleQuery();
  }
  #end

  /** Add */
  function handleAdd(row) {
    reset();
    getTreeselect();
    if (row != null && row.${treeCode}) {
    form.value.${treeParentCode} = row.${treeCode};
  } else {
    form.value.${treeParentCode} = 0;
  }
  open.value = true;
  title.value = t('${moduleName}.${businessName}.addTitle');
}

/** Expand or collapse */
function toggleExpandAll() {
  refreshTable.value = false;
  isExpandAll.value = !isExpandAll.value;
  nextTick(() => {
    refreshTable.value = true;
  });
}

/** Update */
async function handleUpdate(row) {
  loading.value = true;
  reset();
  await getTreeselect();
  if (row != null) {
    form.value.${treeParentCode} = row.${treeParentCode};
  }
  get${BusinessName}(row.${pkColumn.javaField}).then(response => {
    loading.value = false;
    form.value = response.data;
  #foreach ($column in $columns)
#if($column.htmlType == "checkbox")
    form.value.$column.javaField = form.value.${column.javaField}.split(",");
  #end
#end
  open.value = true;
  title.value = t('${moduleName}.${businessName}.editTitle');
  });
}

/** Submit */
function submitForm() {
  proxy.#[[$]]#refs["${businessName}Ref"].validate(valid => {
    if (valid) {
      buttonLoading.value = true;
#foreach ($column in $columns)
#if($column.htmlType == "checkbox")
      form.value.$column.javaField = form.value.${column.javaField}.join(",");
#end
#end
      if (form.value.${pkColumn.javaField} != null) {
        update${BusinessName}(form.value).then(response => {
          proxy.#[[$modal]]#.msgSuccess(t('common.editSuccess'));
          open.value = false;
          getList();
        }).finally(() => {
          buttonLoading.value = false;
        });
      } else {
        add${BusinessName}(form.value).then(response => {
          proxy.#[[$modal]]#.msgSuccess(t('common.addSuccess'));
          open.value = false;
          getList();
        }).finally(() => {
          buttonLoading.value = false;
        });
      }
    }
  });
}

/** Delete */
function handleDelete(row) {
  proxy.#[[$modal]]#.confirm(t('${moduleName}.${businessName}.deleteConfirm', { ids: row.${pkColumn.javaField} })).then(function() {
    loading.value = true;
    return del${BusinessName}(row.${pkColumn.javaField});
  }).then(() => {
    loading.value = false;
    getList();
    proxy.#[[$modal]]#.msgSuccess(t('common.deleteSuccess'));
  }).catch(() => {
  }).finally(() => {
    loading.value = false;
  });
}

getList();
</script>
