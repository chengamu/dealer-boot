/**
 * ${functionName} 服务实现层
 *
 * @author ${author}
 */
@Service
@RequiredArgsConstructor
public class ${ClassName}ServiceImpl extends BaseServiceImpl<${ClassName}Mapper, ${ClassName}, ${ClassName}Vo> implements ${ClassName}Service {

    /**
     * 查询${functionName}列表
     *
     * @param bo ${functionName}业务对象
     * @param pageQuery 分页参数
     * @return ${functionName}分页数据
     */
    @Override
    public TableDataInfo<${ClassName}Vo> queryPageList(${ClassName}Bo bo, PageQuery pageQuery) {
        LambdaQueryWrapper<${ClassName}> lqw = buildQueryWrapper(bo);
        Page<${ClassName}Vo> result = pageVo(pageQuery.build(), lqw);
        return TableDataInfo.build(result);
    }

    /**
     * 查询${functionName}列表
     *
     * @param bo ${functionName}业务对象
     * @return ${functionName}列表
     */
    @Override
    public List<${ClassName}Vo> queryList(${ClassName}Bo bo) {
        LambdaQueryWrapper<${ClassName}> lqw = buildQueryWrapper(bo);
        return listVo(lqw);
    }

    /**
     * 根据ID查询${functionName}
     *
     * @param id ${functionName}主键
     * @return ${functionName}信息
     */
    @Override
    public ${ClassName}Vo queryById(Long id) {
        return getVoById(id);
    }

    /**
     * 新增${functionName}
     *
     * @param bo ${functionName}业务对象
     * @return 是否成功
     */
    @Override
    public Boolean insertByBo(${ClassName}Bo bo) {
        ${ClassName} entity = MapstructUtils.convert(bo, ${ClassName}.class);
        validEntityBeforeSave(entity);
        return save(entity);
    }

    /**
     * 修改${functionName}
     *
     * @param bo ${functionName}业务对象
     * @return 是否成功
     */
    @Override
    public Boolean updateByBo(${ClassName}Bo bo) {
        ${ClassName} entity = MapstructUtils.convert(bo, ${ClassName}.class);
        validEntityBeforeSave(entity);
        return updateById(entity);
    }

    /**
     * 保存前的数据校验
     *
     * @param entity ${functionName}实体
     */
    private void validEntityBeforeSave(${ClassName} entity){
        // TODO 做一些数据校验,如唯一约束
    }

    /**
     * 批量删除${functionName}
     *
     * @param ids 需要删除的${functionName}主键
     * @param isValid 是否校验
     * @return 是否成功
     */
    @Override
    public Boolean deleteWithValidByIds(Collection<Long> ids, Boolean isValid) {
        if(isValid){
            // TODO 做一些业务上的校验,判断是否需要校验
        }
        return removeByIds(ids);
    }

    /**
     * 构建查询条件
     *
     * @param bo ${functionName}业务对象
     * @return 查询条件
     */
    private LambdaQueryWrapper<${ClassName}> buildQueryWrapper(${ClassName}Bo bo) {
        Map<String, Object> params = bo.getParams();
        LambdaQueryWrapper<${ClassName}> lqw = Wrappers.lambdaQuery();
#foreach($column in $columns)
#if($column.isQuery() && !$column.isSuperColumn())
#if($column.htmlType == "input")
        lqw.like(StringUtils.isNotBlank(bo.get${column.capJavaField}()), ${ClassName}::get${column.capJavaField}, bo.get${column.capJavaField}());
#elseif($column.htmlType == "select" || $column.htmlType == "radio")
        lqw.eq(StringUtils.isNotBlank(bo.get${column.capJavaField}()), ${ClassName}::get${column.capJavaField}, bo.get${column.capJavaField}());
#elseif($column.queryType == "BETWEEN")
        lqw.between(params.get("begin${column.capJavaField}") != null && params.get("end${column.capJavaField}") != null,
            ${ClassName}::get${column.capJavaField}, params.get("begin${column.capJavaField}"), params.get("end${column.capJavaField}"));
#else
        lqw.eq(StringUtils.isNotBlank(bo.get${column.capJavaField}()), ${ClassName}::get${column.capJavaField}, bo.get${column.capJavaField}());
#end
#end
#end
        return lqw;
    }

    /**
     * 修改${functionName}状态
     *
     * @param id ${functionName}主键
     * @param status 状态值
     * @return 更新记录数
     */
    @Override
    public int updateStatus(Long id, String status) {
        // 参数校验
        if (id == null) {
            throw new ServiceException(MessageUtils.message("gen.validation.id.required"));
        }
        if (StringUtils.isEmpty(status)) {
            throw new ServiceException(MessageUtils.message("gen.validation.status.required"));
        }

        // 只更新状态字段
        return baseMapper.update(null,
                new LambdaUpdateWrapper<${ClassName}>()
                        .eq(${ClassName}::get${pkColumn.capJavaField}, id)
                        .set(${ClassName}::getStatus, status)
        );
    }

}
