                <artifactId>spring-boot-dependencies</artifactId>
                <version>${spring-boot.version}</version>
                <type>pom</type>
                <scope>import</scope>
                <!-- 璇存槑锛氬鍏pring Boot渚濊禆绠＄悊淇℃伅锛岀粺涓€绠＄悊椤圭洰涓娇鐢ㄧ殑渚濊禆鐗堟湰 -->
            </dependency>
            <!-- 寮曞叆Hutool渚濊禆绠＄悊 -->
