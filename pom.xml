                <groupId>org.apache.velocity</groupId>
                <artifactId>velocity-engine-core</artifactId>
                <version>${velocity.version}</version>
            </dependency>


            <!-- 鏉冮檺涓庢暟鎹簮 -->
            <!-- Sa-Token 鏄竴涓交閲忕骇鐨?Java 鏉冮檺璁よ瘉妗嗘灦锛屾彁渚涙潈闄愯璇併€佹潈闄愭嫤鎴€佽法鍩熻璇併€佽处鍙峰皝绂併€佹帴鍙ｇ鍚嶃€佽姹傞檺娴併€両P 闄愬埗銆侀獙璇佺爜瀵规瘮銆丼ession 绠＄悊绛夊绉嶅姛鑳?-->
            <!-- 寮曞叆 Sa-Token Spring Boot 3.x 鐗堟湰鐨勪緷璧?-->
            <dependency>
                <groupId>cn.dev33</groupId>
                <artifactId>sa-token-spring-boot3-starter</artifactId>
                <version>${satoken.version}</version>
            </dependency>

            <!-- 寮曞叆 Sa-Token JWT 鏀寔锛岀敤浜庡鐞?JSON Web Token -->
